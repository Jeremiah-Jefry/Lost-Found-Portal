# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
env.bak/
venv.bak/

# ── Environment variables / secrets ──────────────────────────────────────────
# Never commit secrets. Set KG_SECRET_KEY as a real env var before deploying.
.env
.env.*
!.env.example

# ── Flask instance folder ─────────────────────────────────────────────────────
# Contains the live SQLite database and any instance-level config overrides.
# Back up instance/kg_portal.db separately; never commit it.
instance/

# ── User-uploaded media ───────────────────────────────────────────────────────
# Runtime data — not source code. Back up out-of-band.
# .gitkeep is excepted so the directory is tracked without its contents.
static/uploads/*
!static/uploads/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── pip / dependency caches ───────────────────────────────────────────────────
pip-log.txt
pip-delete-this-directory.txt

# ── Testing & coverage ────────────────────────────────────────────────────────
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.cache/

# ── Type-checker / linter caches ─────────────────────────────────────────────
.mypy_cache/
.dmypy.json
.ruff_cache/
.pyright/

# ── IDEs and editors ──────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS generated files ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
